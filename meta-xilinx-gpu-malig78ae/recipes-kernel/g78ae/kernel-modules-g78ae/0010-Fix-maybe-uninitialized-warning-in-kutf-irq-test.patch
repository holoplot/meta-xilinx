From 5db9d0a1f38dce31d1ecfe35e9ea4f9fc6327a89 Mon Sep 17 00:00:00 2001
From: Sarangam Manindra <Manindra.Sarangam@amd.com>
Date: Thu, 26 Mar 2026 22:36:00 +0530
Subject: [PATCH] midgard/tests: fix maybe-uninitialized warning in kutf irq
 test

When building with `-Werror`, GCC reports `tval` as potentially
uninitialized in `kbase_gpu_irq_custom_handler()`.

Initialize `tval` to make the control-flow explicit and keep the test
module buildable with stricter warning settings.

Upstream-Status: Pending
Signed-off-by: Sarangam Manindra <Manindra.Sarangam@amd.com>
---
 .../midgard/tests/mali_kutf_irq_test/mali_kutf_irq_test_main.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/gpu/arm/midgard/tests/mali_kutf_irq_test/mali_kutf_irq_test_main.c b/drivers/gpu/arm/midgard/tests/mali_kutf_irq_test/mali_kutf_irq_test_main.c
index c27a6f2..f3b59bb 100644
--- a/drivers/gpu/arm/midgard/tests/mali_kutf_irq_test/mali_kutf_irq_test_main.c
+++ b/drivers/gpu/arm/midgard/tests/mali_kutf_irq_test/mali_kutf_irq_test_main.c
@@ -82,7 +82,7 @@ static irqreturn_t kbase_gpu_irq_custom_handler(int irq, void *data)
 	u32 test_irq = POWER_CHANGED_SINGLE;
 	u32 val = kbase_reg_read32(kbdev, status_reg_enum);
 	irqreturn_t result;
-	u64 tval;
+	u64 tval = 0;
 	bool has_test_irq = val & test_irq;
 
 
-- 
2.34.1
