 .../gpu/arm/midgard/tl/mali_kbase_timeline.c  |  6 +++
 17 files changed, 149 insertions(+), 19 deletions(-)

diff --git a/drivers/gpu/arm/midgard/Kbuild b/drivers/gpu/arm/midgard/Kbuild
index 3d1d0a5..213a75a 100644
--- a/drivers/gpu/arm/midgard/Kbuild
+++ b/drivers/gpu/arm/midgard/Kbuild
@@ -18,9 +18,22 @@
 #
 #
 
-# make $(src) as absolute path if it is not already, by prefixing $(srctree)
-# This is to prevent any build issue due to wrong path.
-src:=$(if $(patsubst /%,,$(src)),$(srctree)/$(src),$(src))
+# make $(src) as absolute path if it is not already, by prefixing $(srctree) or $(srcroot)
+# depending on Kernel Version (use srctree for < 6.13). This is to prevent any build issue
+# due to wrong path.
+ifeq ($(shell expr $(VERSION) \>= 6), 1)
+    ifeq ($(VERSION), 6)
+        ifeq ($(shell expr $(PATCHLEVEL) \< 13), 1)
+            src:=$(if $(patsubst /%,,$(src)),$(srctree)/$(src),$(src))
+        else
+            src:=$(if $(patsubst /%,,$(src)),$(realpath $(srcroot))/$(src),$(src))
+        endif
+    else
+        src:=$(if $(patsubst /%,,$(src)),$(realpath $(srcroot))/$(src),$(src))
+    endif
+else
+    src:=$(if $(patsubst /%,,$(src)),$(srctree)/$(src),$(src))
+endif
 
 #
 # Prevent misuse when Kernel configurations are not present by default
